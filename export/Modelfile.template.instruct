FROM {{GGUF_PATH}}

PARAMETER num_ctx 1024
# Note: These defaults are tuned for the interactive CLI demo experience.
# Evaluation uses API-level overrides (temperature=0, repeat_penalty=1.0,
# top_p=1.0) to ensure deterministic, reproducible results.
PARAMETER num_predict 256
PARAMETER repeat_penalty 1.3
PARAMETER top_p 0.9
PARAMETER temperature 0.8

# Alpaca instruction format template for the SFT model.
# Ollama uses Go templates: {{ .Prompt }} is replaced with the user's input.
# This ensures interactive `ollama run` auto-wraps prompts in the format
# the model was fine-tuned on.
TEMPLATE """### Instruction:
{{ .Prompt }}

### Response:
"""

SYSTEM """{{DISCLAIMER}}"""
